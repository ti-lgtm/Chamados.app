
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null && (
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isSupportStaff() {
      let role = getRole();
      return isSignedIn() && (role == 'ti' || role == 'admin');
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isSupportStaff();
      allow list: if isSignedIn();
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if isOwner(userId) || isSupportStaff();
      allow delete: if isSupportStaff();
    }

    match /tickets/{ticketId} {
      allow get: if isOwner(resource.data.userId) || isSupportStaff();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSupportStaff() || isOwner(resource.data.userId);
      allow delete: if isSupportStaff();

      match /comments/{commentId} {
        allow read, write: if isSignedIn();
      }
      match /ratings/{ratingId} {
        allow read, write: if isSignedIn();
      }
      match /internal_notes/{noteId} {
        allow read, write: if isSupportStaff();
      }
    }

    match /scheduled_tickets/{id} {
      allow read, write: if isSupportStaff();
    }

    match /counters/{counterId} {
      allow read, write: if isSignedIn();
    }
  }
}
