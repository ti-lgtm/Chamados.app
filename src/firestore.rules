rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isSupportStaff() {
      return isSignedIn() && (getRole() == 'ti' || getRole() == 'admin');
    }

    function isAdmin() {
      return isSignedIn() && getRole() == 'admin';
    }

    // PRIORIDADE: Base de Conhecimento (Leitura para todos logados, Escrita para equipe)
    match /knowledge_base/{articleId} {
      allow read: if request.auth != null;
      allow write: if isSupportStaff();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isSupportStaff());
      allow list: if isSignedIn();
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isSupportStaff());
      allow delete: if isAdmin();
    }

    match /tickets/{ticketId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isSupportStaff());
      allow list: if isSignedIn();
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || (isSupportStaff() && request.resource.data.userId == 'system'));
      allow update: if isSignedIn() && (isSupportStaff() || resource.data.userId == request.auth.uid);
      allow delete: if isSupportStaff();

      match /comments/{commentId} {
        allow read, write: if isSignedIn();
      }
      match /ratings/{ratingId} {
        allow read, write: if isSignedIn();
      }
      match /internal_notes/{noteId} {
        allow read, write: if isSupportStaff();
      }
    }

    match /scheduled_tickets/{id} {
      allow read, write: if isSupportStaff();
    }

    match /counters/{counterId} {
      allow read, write: if isSignedIn();
    }

    match /room_images/{roomId} {
      allow read: if isSignedIn();
      allow write: if isSupportStaff();
    }
  }
}