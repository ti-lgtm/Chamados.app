
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "suspended"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "receivesEmails": { "type": "boolean" },
        "notificationSoundUrl": { "type": "string", "format": "uri" }
      },
      "required": ["uid", "name", "email", "role", "createdAt", "status"]
    },
    "Ticket": {
      "title": "Ticket",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ticketNumber": { "type": "number" },
        "type": { "type": "string", "enum": ["support", "purchase"] },
        "title": { "type": "string" },
        "company": { "type": "string" },
        "department": { "type": "string" },
        "service": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "in_progress", "resolved", "awaiting_user", "awaiting_support", "in_quotation", "purchased", "delivered"] },
        "priority": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expectedDeliveryDate": { "type": "string", "format": "date-time" },
        "purchaseDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "ticketNumber", "type", "title", "status", "userId", "createdAt"]
    },
    "KnowledgeBaseArticle": {
        "title": "Knowledge Base Article",
        "type": "object",
        "properties": {
            "id": { "type": "string" },
            "title": { "type": "string" },
            "description": { "type": "string" },
            "link": { "type": "string", "format": "uri" },
            "category": { "type": "string" },
            "isFeatured": { "type": "boolean" },
            "order": { "type": "number" },
            "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "title", "description", "link", "category", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/users/{userId}": { "schema": "#/backend/entities/User", "description": "Stores user profiles." },
    "/tickets/{ticketId}": { "schema": "#/backend/entities/Ticket", "description": "Stores support tickets and purchases." },
    "/knowledge_base/{articleId}": { "schema": "#/backend/entities/KnowledgeBaseArticle", "description": "Stores knowledge base procedures and articles." }
  }
}
